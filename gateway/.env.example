# Gateway environment
PORT=8080
JWT_SECRET=changeme
# Prisma connection to Render Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads

# App to Gateway shared secret for token exchange
APP_SHARED_SECRET=change-me-strong-secret

# Notes:
# - /api/auth/signup and /api/auth/login use email only (placeholder until OpenSaaS auth integration).
# - /api/filing/generate returns a PDF, ensure client handles application/pdf.
# - /api/files/upload expects multipart/form-data with field name 'file' and optional orgId.
# - /api/auth/exchange expects HMAC-SHA256 signature: hex(HMAC(secret, `${userId}.${email}.${orgId}.${timestamp}`))

# IRS Sync Job
GOVINFO_API_KEY=
IRS_DEVHUB_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tax_programs
QDRANT_VECTOR_SIZE=384
# On Render, ensure Playwright browsers are installed during build: `npx playwright install --with-deps`

# DeepSeek (RAG inference)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
