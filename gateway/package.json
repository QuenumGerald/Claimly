{
  "name": "gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --esm --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema ../app/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.2.0",
    "pino": "^9.4.0",
    "prisma": "5.19.1",
    "@prisma/client": "5.19.1",
    "zod": "^3.25.6",
    "dotenv": "^16.4.5",
    "minio": "^8.0.1",
    "pdfkit": "^0.15.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "@types/node": "^20.14.14"
  }
}
